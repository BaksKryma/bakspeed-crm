# ==== FRONTEND (Vite, prefix VITE_) ====
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=...

# ==== BACKEND (Edge Functions secrets — `supabase secrets set ...`) ====
# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...

# Fleet Hand (optional — fallback: OSRM + Nominatim)
FLEETHAND_TOKEN=

# Saldeo (optional — fallback: local invoice PDF only)
SALDEO_API_KEY=

# Notifications
TELEGRAM_BOT_TOKEN=
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+48...

# App URL (used in driver brief SMS link)
APP_URL=https://app.bakspeed.pl

# ==== SCRIPTS (imports) ====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
FILE=/path/to/LOADS-INFO.xlsx
